# ============================================================================
#  Pulse — environment variables (LOCAL DEVELOPMENT)
# ----------------------------------------------------------------------------
#  Copy this file to `.env` and fill in only what you need:
#
#      cp .env.example .env
#
#  These values are read by the monitoring engine (`npm run monitor`) and the
#  setup/seed scripts when you run them on your machine. They are referenced
#  inside pulse.config.yaml as ${ENV_VAR}.
#
#  ⚠️  IN PRODUCTION, DO NOT USE THIS FILE.
#      • Engine secrets → GitHub Actions secrets (Settings → Secrets → Actions)
#      • Cloudflare secrets → GitHub Actions secrets (used by deploy.yml)
#      • `.env` is git-ignored — never commit real tokens anywhere.
# ============================================================================

# ── Telegram ────────────────────────────────────────────────────────────────
# Create a bot with @BotFather → it gives you the token.
# Get your chat id by messaging the bot and calling getUpdates (see docs/notifications.md).
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTuVWxyZ
TELEGRAM_CHAT_ID=-1001234567890
# Optional per-client/extra chat (referenced by the example "telegram-acme" channel).
ACME_TELEGRAM_CHAT_ID=-1009876543210

# ── Email (Resend) ───────────────────────────────────────────────────────────
# https://resend.com → API Keys. Verify your sending domain for best deliverability.
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx

# ── Discord ──────────────────────────────────────────────────────────────────
# Server Settings → Integrations → Webhooks → New Webhook → Copy URL.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/000000000000000000/xxxxxxxx

# ── Slack ────────────────────────────────────────────────────────────────────
# https://api.slack.com/messaging/webhooks → Incoming Webhooks.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxxxxxxxxxx

# ── Generic webhook (optional) ───────────────────────────────────────────────
# Any URL that should receive the raw JSON event payload (PagerDuty, n8n, etc.).
PAGER_WEBHOOK_URL=https://example.com/hooks/pulse

# ── Authenticated probes (optional) ──────────────────────────────────────────
# Example: a bearer token injected into a site's request headers in the config.
BILLING_API_TOKEN=secret-token-value

# ============================================================================
#  Cloudflare Pages deploy
#  Only needed if you deploy from your machine with `wrangler` instead of the
#  GitHub Action. In CI these live as GitHub Actions secrets.
# ============================================================================
CLOUDFLARE_API_TOKEN=cf_xxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_ACCOUNT_ID=0123456789abcdef0123456789abcdef

# ============================================================================
#  Dashboard (Vite) — build/runtime knobs. All optional; sensible defaults apply.
#  Prefix MUST be VITE_ to be exposed to the browser bundle.
# ============================================================================
# Base path the SPA fetches /data JSON from. Default: "/data".
# VITE_DATA_BASE=/data
# How often (ms) the dashboard re-fetches summary.json. Default: 60000.
# VITE_REFRESH_MS=60000
# Local-only RBAC simulation (Cloudflare Access provides identity in prod).
# Lets you preview the dashboard as a given role/email without signing in.
# VITE_DEV_ROLE=SUPER_ADMIN
# VITE_DEV_EMAIL=you@example.com
